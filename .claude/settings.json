{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Fetch",
      "WebFetch",
      "WebSearch",
      "Bash(/usr/bin/make:*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(cp:*)",
      "Bash(docker:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(pnpm:*)",
      "Bash(printf:*)",
      "Bash(rg:*)",
      "Bash(shuf:*)",
      "Bash(tail:*)",
      "Bash(test:*)",
      "Bash(tmux:*)",
      "Bash(tree:*)",
      "Bash(which:*)",
      "Bash(vercel:*)",
      "Bash(yarn:*)",
      "Bash(yes)",
      "mcp__*"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.kube/config)",
      "Read(~/.netrc)",
      "Read(~/Library/Keychains/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/id_ecdsa)",
      "Read(**/id_dsa)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/credentials.json)",
      "Read(**/secrets.json)",
      "Read(**/service-account*.json)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(~/.gnupg/**)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf $HOME/*)",
      "Bash(rm -fr /)",
      "Bash(rm -fr /*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(halt:*)",
      "Bash(poweroff:*)",
      "Bash(diskutil:*)",
      "Bash(launchctl:*)",
      "Bash(chmod -R 777 /)",
      "Bash(chmod -R 777 /*)",
      "Bash(chown -R *)",
      "Bash(eval:*)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git push:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(rm:*)",
      "Bash(sudo:*)"
    ],
    "defaultMode": "plan"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/security-audit.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "tmux-agent-sidebar@hiroppy": true
  },
  "extraKnownMarketplaces": {
    "hiroppy": {
      "source": {
        "source": "directory",
        "path": "~/.tmux/plugins/tmux-agent-sidebar"
      }
    }
  },
  "language": "Japanese",
  "effortLevel": "max",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "showThinkingSummaries": true,
  "voiceEnabled": true
}
